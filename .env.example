# Firebase (required for auth + parent links in production)
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abc123
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Subscription API (set when using Paygate + Supabase)
# VITE_SUBSCRIPTION_API_URL=https://your-app.vercel.app/api

# Phase 2: Google & Microsoft integration
# Google: Create project at console.cloud.google.com, enable Classroom API, create OAuth 2.0 Web client
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Microsoft: Azure AD app registration, add redirect URI from Firebase
VITE_MICROSOFT_TENANT_ID=common
